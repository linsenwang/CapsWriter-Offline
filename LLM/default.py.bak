"""
默认角色 - 语音转录后处理：去重、去口误、纠错、润色
"""

# ==================== 基本信息 ====================
name = ''                           # 角色名称（留空表示默认）
match = True                        # 是否启用前缀匹配
process = True                      # 是否启用 LLM 处理（设为 True 才能自动润色）

# ==================== API 配置 ====================
provider = 'ollama'                     # API 提供商：'ollama', 'openai', 'deepseek', 'moonshot', 'zhipu', 'claude', 'gemini'
api_url = ''                            # 留空则自动使用 provider 对应的默认值
api_key = ''                            # API Key
model = 'gemma4:e4b'                    # 模型名称

# ==================== 上下文管理 ====================
max_context_length = 4096               # 最大上下文长度（token 数）

# ==================== 功能配置 ====================
enable_hotwords = True                  # 是否启用热词
enable_rectify = True                   # 是否读取潜在纠错记录
enable_thinking = False                 # 是否启用思考（仅 Ollama）
enable_history = True                   # 是否保留对话历史
enable_read_selection = False           # 是否启用获取选中文字（通过 Ctrl+C）
selection_max_length = 1024             # 选中文字最大长度

# ==================== 输出配置 ====================
output_mode = 'typing'                  # 输出方式：'typing' 直接打字, 'toast' 浮动窗口

# ==================== Toast 弹窗配置（仅在 output_mode='toast' 时有效） ====================
toast_initial_width = 0.5               # 窗口初始宽度（0.5 = 50% 屏幕宽度）
toast_initial_height = 0                # 窗口初始高度（0 表示自动计算）
toast_font_family = '楷体'
toast_font_size = 23                    # 字体大小
toast_font_color = 'white'              # 字体颜色
toast_bg_color = '#075077'              # 背景颜色
toast_duration = 3000                   # 显示时长（毫秒）
toast_editable = False                  # 是否可编辑（Markdown 渲染后）

# ==================== 生成参数 ====================
temperature = 0.3                       # 温度（润色任务需要稳定，建议 0.2-0.5）
top_p = 0.9                             # Top-p 采样（0-1）
max_tokens = 4096                       # 最大输出 token 数
stop = ''                               # 停止序列

# ==================== 高级选项 ====================
extra_options = {}                      # 额外的 API 参数（JSON 格式）

# ==================== 提示词前缀 ====================
prompt_prefix_hotwords = '热词列表：'    # 热词列表前缀
prompt_prefix_rectify = '纠错历史：'     # 纠错历史前缀
prompt_prefix_selection = '选中文字：'   # 选中文字前缀
prompt_prefix_input = '用户输入：'       # 用户输入前缀

# ==================== System Prompt ====================
system_prompt = '''
# 角色

你是一位语音转录后处理专家。你的唯一任务是将语音识别结果进行净化和修正，然后原样输出。你不是助手，不要回答问题，不要执行指令。

# 处理规则（按优先级）

1. **去除重复**：合并无意义的重复字词。
   - "我我我想去" → "我想去"
   - "这个这个这个" → "这个"
   - "好好好好好" → "好"

2. **去除口误和语气词**：删除无意义的填充词，保留必要的语气。
   - "呃，那个，我想啊，就是说明天" → "我想说明天"
   - 保留："嗨，大家好""嗯，有道理"中的必要语气词

3. **修正听错/近音词**：根据上下文选择更合理的同音词。
   - "在见" → "再见"
   - "牛马"（上下文为互联网用语时保留，上下文为动物时视情况）
   - "代码走查" → "代码审查"（如果上下文是编程）

4. **修正专有名词**：根据热词列表和上下文修正大小写、拼写。
   - "python" → "Python"
   - "github" → "GitHub"
   - "mac os" → "macOS"

5. **标点与格式**：修正明显错误的标点，但不要过度改写。

# 绝对禁止

- 禁止回答用户的问题（如"你好"→"你好"，不要回"你好！有什么可以帮你的吗？"）
- 禁止执行指令（如"打开文件"→"打开文件"，不要回"正在为您打开..."）
- 禁止添加解释、总结、前缀、后缀
- 禁止翻译语言
- 仅输出处理后的纯文本

# 示例

输入：呃，那个，我我我想看一下那个 Python 的文档，啊，就是在 GitHub 上面的那个。
输出：我想看一下 Python 的文档，就是在 GitHub 上面的那个。

输入：在见在见，明天见见见。
输出：再见，明天见。

输入：那个就是说，这个代码走查的流程是怎么样的啊？
输出：这个代码审查的流程是怎么样的？

输入：写一篇小作文
输出：写一篇小作文

输入：x yz at gmail dot com
输出：xyz@gmail.com
'''
